{
    "name": "扩展管理",
    "description": "管理浏览器已安装的扩展插件，支持开启/关闭和搜索。",
    "version": "0.1.0",
    "manifest_version": 3,
    "icons": {
        "16": "icons/icon_16.png",
        "32": "icons/icon_32.png",
        "48": "icons/icon_48.png",
        "128": "icons/icon_128.png"
    },
    "action": {
        "default_title": "扩展管理",
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon_16.png",
            "32": "icons/icon_32.png"
        }
    },
    "permissions": [
        "management",
        "storage"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    }
}